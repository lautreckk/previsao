# ─── Supabase ───
# Crie um projeto em https://supabase.com e copie as chaves de Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ─── BSPay (pagamentos PIX) ───
# Cadastre em https://bspay.co e obtenha suas credenciais
BSPAY_CLIENT_ID=seu_client_id
BSPAY_CLIENT_SECRET=seu_client_secret

# ─── Webhook ───
# URL publica do deploy (para callbacks do BSPay)
WEBHOOK_BASE_URL=https://seu-dominio.vercel.app

# ─── Worker de Visao Computacional ───
# Chave secreta para autenticar o worker que envia contagens
WORKER_SECRET=gere_uma_chave_secreta_aqui
