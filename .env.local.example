# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key

# Cron
CRON_SECRET=your_cron_secret

# Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password
ADMIN_SECRET=your_admin_secret

# Worker
WORKER_SECRET=your_worker_secret

# BSPay
BSPAY_CLIENT_ID=your_bspay_client_id
BSPAY_CLIENT_SECRET=your_bspay_client_secret

# Webhook
WEBHOOK_BASE_URL=https://your-domain.vercel.app
WEBHOOK_SECRET=generate_a_random_secret_here

# APIs externas
OPENWEATHER_API_KEY=your_openweather_api_key
FOOTBALL_DATA_KEY=your_football_data_key
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_access_token
